# Host port the app listens on. Defaults to 8080.
# Do NOT expose this to the public internet; there is no auth.
# HOST_PORT=8080

# The app auto-generates and persists a 32-byte AES key on first boot;
# you don't need to set anything here for a default install. If you
# want to manage the key externally (KMS, sealed secrets, etc.) set
# MASTER_KEY=<base64-32-bytes> and uncomment the line in compose.
# Generate: openssl rand -base64 32
# MASTER_KEY=
