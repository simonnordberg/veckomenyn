# 32-byte AES master key for encrypting provider secrets (API keys,
# passwords, Willys session cookies) at rest. Strongly recommended;
# without it everything in the providers and willys_session tables
# lives in cleartext and the server logs a warning at boot.
#
# Generate with:
#   openssl rand -base64 32
# MASTER_KEY=

# Host port the app listens on. Defaults to 8080.
# Do NOT expose this to the public internet; there is no auth.
# HOST_PORT=8080
